local function getSlot()
    if isfile(autoLoadPath) then
        local content = readfile(autoLoadPath)
        content = tostring(content):gsub("\n", ""):gsub("\r", "")

        if content == "A" then
            return "A"
        elseif content == "B" then
            return "B"
        elseif content == "C" then
            return "C"
        end
    end

    return "UNKNOWN"
end

